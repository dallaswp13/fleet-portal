# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# IBM MaaS360 (XML API credentials)
MAAS360_BASE_URL=https://services.m3.maas360.com
MAAS360_BILLING_ID=your-billing-id
MAAS360_PLATFORM_ID=3
MAAS360_APP_ID=your-app-id
MAAS360_APP_VERSION=1.0
MAAS360_APP_ACCESS_KEY=your-app-access-key
MAAS360_USERNAME=your-maas360-username
MAAS360_PASSWORD=your-maas360-password

# Twilio (SMS webhook + outbound auto-reply)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Either MESSAGING_SERVICE_SID OR PHONE_NUMBER is required for outbound sends.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+15555551234

# Anthropic (Claude intent parsing)
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAIL=admin@company.com
CRON_SECRET=generate-a-random-secret

# M360 Service Configuration
# Copy to .env and fill in real values

# ── Service ──
PORT=3360
M360_ENV=sandbox          # "production" | "sandbox" — sandbox logs calls but never hits real M360
API_KEYS=fp_live_abc123,fp_test_xyz789   # comma-separated API keys for authenticating callers

# ── MaaS360 Credentials ──
MAAS360_BASE_URL=https://services.m3.maas360.com
MAAS360_BILLING_ID=
MAAS360_PLATFORM_ID=3
MAAS360_APP_ID=
MAAS360_APP_VERSION=1.0
MAAS360_APP_ACCESS_KEY=
MAAS360_USERNAME=
MAAS360_PASSWORD=

# ── Optional ──
DISPATCH_APP_PACKAGE=com.ccsi.taxidispatch
LOG_LEVEL=info             # "debug" | "info" | "warn" | "error"
